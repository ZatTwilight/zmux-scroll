#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

plugin_name="zmux-scroll"
target="${RUST_TARGET:-wasm32-wasip1}"
plugin_dir="${ZELLIJ_PLUGIN_DIR:-$HOME/.config/zellij/plugins}"
plugin_path="$plugin_dir/$plugin_name.wasm"
build_artifact="target/$target/release/$plugin_name.wasm"

cargo_build=(cargo build --release --target "$target")
if [[ "${ZMUX_SCROLL_DEBUG:-}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  cargo_build+=(--features debug-logs)
fi

"${cargo_build[@]}"

mkdir -p "$plugin_dir"
cp "$build_artifact" "$plugin_path"

zellij action start-or-reload-plugin "file:$plugin_path"
